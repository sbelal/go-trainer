    "title": "go.mod exists in app directory",
    "type": "command",
    "command": "node -e \"if (!require('fs').existsSync('app/go.mod')) process.exit(1)\"",
    "expect": {
      "exitCode": 0
    },
    "fix": {
      "file": "README.md",
      "section": "Step 1: Create the App Directory and Initialize the Module"
    }
  },
  {
    "id": "go-mod-content",
    "title": "go.mod initializes module 'todo-api'",
    "type": "command",
    "command": "node -e \"const f = require('fs').readFileSync('app/go.mod', 'utf8'); if (!f.includes('module todo-api')) process.exit(1)\"",
    "expect": {
